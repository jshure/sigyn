{
  "debug": false,
  "tenant_id": "",
  "ingester": {
    "listen_address": ":3100",
    "batch_size_bytes": 5242880,
    "batch_time_window_sec": 30,
    "compression_algo": "gzip",
    "max_body_bytes": 10485760,
    "max_entries_per_request": 10000,
    "rate_limit_rps": 0,
    "wal_dir": "",
    "tls": {
      "enabled": false,
      "cert_file": "",
      "key_file": ""
    },
    "min_level": ""
  },
  "storage": {
    "s3": {
      "bucket": "agent-vibe-log-archive",
      "region": "us-west-2",
      "prefix": "raw_logs/",
      "endpoint": "",
      "use_path_style": false,
      "retention_days": 90
    },
    "index": {
      "prefix": "index/"
    }
  },
  "exporter": {
    "listen_address": ":8080",
    "opensearch": {
      "endpoint": "https://search-my-log-domain.us-west-2.es.amazonaws.com",
      "index_prefix": "exported-logs-",
      "username": "${OS_USERNAME}",
      "password": "${OS_PASSWORD}"
    },
    "default_batch_size": 1000,
    "max_concurrent_jobs": 4,
    "ingester_url": "ws://localhost:3100"
  },
  "auth": {
    "enabled": false,
    "api_keys": []
  },
  "metrics": {
    "enabled": false,
    "address": ":9090"
  }
}
